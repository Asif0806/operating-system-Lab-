Closes an opened file.
Releases the associated system resources.
(c) C-based system call sequence to open a file, read its contents, and close it. )
#include <fcntl.h>
#include <unistd.h>
#include <stdio.h>

int main() {
    int fd;
    char buffer[100];
    int bytes;

    fd = open("student.txt", O_RDONLY);

    bytes = read(fd, buffer, sizeof(buffer) - 1);
    buffer[bytes] = '\0';

    printf("%s", buffer);

    close(fd);

    return 0;
}
